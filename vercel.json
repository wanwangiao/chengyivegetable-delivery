{
  "version": 2,
  "builds": [
    {
      "src": "src/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/css/(.*)",
      "dest": "/public/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/public/js/$1"
    },
    {
      "src": "/images/(.*)",
      "dest": "/public/images/$1"
    },
    {
      "src": "/api/driver/(.*)",
      "dest": "/src/server.js"
    },
    {
      "src": "/api/customer/(.*)",
      "dest": "/src/server.js"
    },
    {
      "src": "/api/admin/reports/(.*)",
      "dest": "/src/server.js"
    },
    {
      "src": "/ws/(.*)",
      "dest": "/src/server.js"
    },
    {
      "src": "/track-order/(.*)",
      "dest": "/src/server.js"
    },
    {
      "src": "/driver/dashboard-gps",
      "dest": "/src/server.js"
    },
    {
      "src": "/admin/driver-performance",
      "dest": "/src/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/src/server.js"
    }
  ],
  "env": {
    "DATABASE_URL": "postgresql://postgres.cywcuzgbuqmxjxwyrrsp:@chengyivegetable@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres",
    "NODE_ENV": "production"
  }
}