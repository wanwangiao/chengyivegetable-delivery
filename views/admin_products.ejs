<!DOCTYPE html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8">
    <title>後台｜商品管理</title>
    <link rel="stylesheet" href="/css/styles.css">
  </head>
  <body>
    <h1>商品管理</h1>
    <p><a href="/admin/orders">訂單列表</a> | <a href="/admin/products/new">新增商品</a> | <a href="/admin/logout">登出</a></p>
    <% if (!products || products.length === 0) { %>
      <p>沒有商品。</p>
    <% } else { %>
      <form method="post">
        <table class="admin-table" border="1" cellspacing="0" cellpadding="5">
          <thead>
            <tr>
              <th>品名</th>
              <th>價格（固定價）</th>
              <th>計價商品</th>
              <th>單位/說明</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% products.forEach(function(p) { %>
              <tr>
                <form method="post" action="/admin/products/<%= p.id %>/update">
                <td><%= p.name %></td>
                <td><input type="number" step="0.01" name="price" value="<%= p.price || '' %>"></td>
                <td><input type="checkbox" name="isPricedItem" <%= p.is_priced_item ? 'checked' : '' %>></td>
                <td><input type="text" name="unitHint" value="<%= p.unit_hint || '' %>"></td>
                <td><button type="submit">更新</button></td>
                </form>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </form>
    <% } %>
  </body>
</html>