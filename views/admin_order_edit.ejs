<!DOCTYPE html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8">
    <title>編輯訂單 <%= order.id %></title>
    <link rel="stylesheet" href="/css/styles.css">
  </head>
  <body>
    <h1>編輯訂單 <%= order.id %></h1>
    <p>客戶：<%= order.contact_name %>（<%= order.contact_phone %>）</p>
    <p>地址：<%= order.address %></p>
    <p>狀態：<%= order.status %></p>
    <form method="post" action="/admin/orders/<%= order.id %>">
      <table class="admin-table" border="1" cellspacing="0" cellpadding="5">
        <thead>
          <tr>
            <th>品名</th>
            <th>類型</th>
            <th>數量</th>
            <th>單價</th>
            <th>小計（可編輯）</th>
            <th>實際重量</th>
          </tr>
        </thead>
        <tbody>
          <% order.items.forEach(function(item) { %>
            <tr>
              <td><%= item.name %></td>
              <td><%= item.is_priced_item ? '計價商品' : '固定價' %></td>
              <td><%= item.quantity %></td>
              <td><%= item.unit_price ? '$' + item.unit_price : '-' %></td>
              <td>
                <% if (item.is_priced_item) { %>
                  <input type="number" name="lineTotal" step="0.01" value="<%= item.line_total %>" required>
                <% } else { %>
                  $<%= item.line_total %>
                  <input type="hidden" name="lineTotal" value="<%= item.line_total %>">
                <% } %>
              </td>
              <td>
                <% if (item.is_priced_item) { %>
                  <input type="number" name="actualWeight" step="0.01" value="<%= item.actual_weight || '' %>">
                <% } else { %>
                  <input type="hidden" name="actualWeight" value="">
                  -
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
      <p>小計：$<%= order.subtotal %></p>
      <p>運費：$<%= order.delivery_fee %></p>
      <p>總計：$<%= order.total %></p>
      <button type="submit">更新金額</button>
    </form>
    <p><a href="/admin/orders">回訂單列表</a></p>
  </body>
</html>