<!DOCTYPE html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8">
    <title>管理員登入</title>
    <link rel="stylesheet" href="/css/styles.css">
  </head>
  <body>
    <h1>後台登入</h1>
    <% if (error) { %>
      <p style="color:red"><%= error %></p>
    <% } %>
    <form method="post" action="/admin/login">
      <label>密碼：<input type="password" name="password" required></label>
      <button type="submit">登入</button>
    </form>
  </body>
</html>