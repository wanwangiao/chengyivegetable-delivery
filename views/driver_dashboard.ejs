        // 處理訂單操作
        async function handleOrderAction() {
            if (!currentOrderId || !currentAction) return;
            
            // 顯示確認對話框
            const confirmed = await showConfirmDialog(currentAction, currentOrderId);
            if (!confirmed) return;
            
            try {
                let response;
                if (currentAction === 'take') {
                    response = await fetch(`/api/driver/take-order/${currentOrderId}`, {
                        method: 'POST'
                    });
                } else if (currentAction === 'complete') {
                    response = await fetch(`/api/driver/complete-order/${currentOrderId}`, {
                        method: 'POST'
                    });
                }
                
                const result = await response.json();
                
                if (result.success) {
                    if (currentAction === 'take') {
                        showNotification('✅ 訂單接取成功！', 'success', {
                            duration: 3000,
                            actions: [
                                { label: '查看我的配送', handler: 'showTab("my-orders")' }
                            ]
                        });
                    } else {
                        showNotification('🎉 配送完成！客戶已收到通知', 'success', {
                            duration: 5000,
                            actions: [
                                { label: '查看完成記錄', handler: 'showTab("completed")' },
                                { label: '繼續配送', handler: 'showTab("available")' }
                            ]
                        });
                    }
                    closeOrderModal();
                    
                    // 重新載入所有訂單列表
                    await Promise.all([
                        loadAvailableOrders(),
                        loadMyOrders(), 
                        loadCompletedOrders()
                    ]);
                    updateStats();
                } else {
                    showNotification(result.message || '操作失敗', 'error');
                }
            } catch (error) {
                console.error('操作失敗:', error);
                showNotification('❌ 操作失敗，請檢查網路連線', 'error', {
                    duration: 6000,
                    actions: [
                        { label: '重試', handler: 'performOrderAction()' },
                        { label: '刷新頁面', handler: 'location.reload()' }
                    ]
                });
            }
        }

