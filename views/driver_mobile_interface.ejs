<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>外送員配送介面</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'PingFang TC', 'Microsoft JhengHei', sans-serif;
            background: #000;
            color: #fff;
            overflow: hidden;
            height: 100vh;
            position: relative;
        }
        
        /* 地圖容器 - 佔80%螢幕 */
        #map-container {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 80vh;
            z-index: 1;
        }
        
        #google-map {
            width: 100%;
            height: 100%;
        }
        
        /* GPS定位按鈕 */
        .gps-button {
            position: absolute;
            top: 20px;
            right: 20px;
            width: 50px;
            height: 50px;
            background: rgba(0, 0, 0, 0.8);
            border-radius: 50%;
            border: none;
            color: #00d4aa;
            font-size: 20px;
            cursor: pointer;
            z-index: 10;
            transition: all 0.3s;
        }
        
        .gps-button:hover {
            background: rgba(0, 0, 0, 0.9);
            transform: scale(1.05);
        }
        
        /* 底部狀態列 - 佔20%螢幕 */
        .bottom-status-bar {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 20vh;
            background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
            z-index: 5;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .bottom-status-bar:hover {
            background: linear-gradient(135deg, #2d2d2d 0%, #404040 100%);
        }
        
        /* 狀態列內容 */
        .status-content {
            padding: 15px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 100%;
        }
        
        .delivery-info {
            flex: 1;
        }
        
        .delivery-info h3 {
            color: #00d4aa;
            font-size: 18px;
            margin-bottom: 5px;
        }
        
        .delivery-info .distance {
            font-size: 16px;
            color: #fff;
            margin-bottom: 3px;
        }
        
        .delivery-info .eta {
            font-size: 14px;
            color: #aaa;
        }
        
        .pull-indicator {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: rgba(0, 212, 170, 0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #00d4aa;
            font-size: 20px;
            animation: bounce 2s infinite;
        }
        
        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-5px); }
        }
        
        /* 可拉升的訂單面板 */
        .orders-panel {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 85vh;
            background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
            border-radius: 25px 25px 0 0;
            transform: translateY(65vh);
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 15;
            box-shadow: 0 -10px 30px rgba(0, 0, 0, 0.5);
        }
        
        .orders-panel.expanded {
            transform: translateY(0);
        }
        
        /* 面板拖拉手柄 */
        .panel-handle {
            width: 50px;
            height: 5px;
            background: #555;
            border-radius: 3px;
            margin: 15px auto;
            cursor: pointer;
        }
        
        /* 訂單列表 */
        .orders-header {
            padding: 0 25px 15px;
            border-bottom: 1px solid #333;
        }
        
        .orders-header h2 {
            color: #00d4aa;
            font-size: 20px;
            margin-bottom: 5px;
        }
        
        .orders-summary {
            color: #aaa;
            font-size: 14px;
        }
        
        .orders-list {
            padding: 20px 25px;
            overflow-y: auto;
            height: calc(85vh - 120px);
        }
        
        /* 正在配送的訂單 */
        .current-order {
            background: linear-gradient(135deg, #00d4aa 0%, #00b894 100%);
            padding: 20px;
            border-radius: 15px;
            margin-bottom: 15px;
            position: relative;
            overflow: hidden;
        }
        
        .current-order::before {
            content: '✓';
            position: absolute;
            left: -10px;
            top: -10px;
            width: 40px;
            height: 40px;
            background: #fff;
            color: #00d4aa;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            font-weight: bold;
        }
        
        .current-order h3 {
            color: #fff;
            font-size: 16px;
            margin-bottom: 8px;
            margin-left: 20px;
        }
        
        .current-order .order-address {
            color: rgba(255, 255, 255, 0.9);
            font-size: 14px;
            margin-left: 20px;
        }
        
        /* 已完成訂單 */
        .completed-orders {
            margin-bottom: 20px;
        }
        
        .completed-orders h3 {
            color: #666;
            font-size: 16px;
            margin-bottom: 10px;
            padding-left: 10px;
        }
        
        .completed-order {
            background: rgba(255, 255, 255, 0.05);
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 10px;
            opacity: 0.6;
            border-left: 4px solid #666;
        }
        
        .completed-order h4 {
            color: #666;
            font-size: 14px;
            margin-bottom: 5px;
        }
        
        .completed-order .order-address {
            color: #555;
            font-size: 12px;
        }
        
        /* 待配送訂單 */
        .pending-orders h3 {
            color: #fff;
            font-size: 16px;
            margin-bottom: 10px;
            padding-left: 10px;
        }
        
        .pending-order {
            background: rgba(255, 255, 255, 0.1);
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 10px;
            border-left: 4px solid #ffd93d;
        }
        
        .pending-order h4 {
            color: #fff;
            font-size: 14px;
            margin-bottom: 5px;
        }
        
        .pending-order .order-address {
            color: #aaa;
            font-size: 12px;
        }
        
        /* 完成配送按鈕 */
        .complete-delivery-btn {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            background: linear-gradient(135deg, #00d4aa 0%, #00b894 100%);
            color: #fff;
            border: none;
            padding: 15px 30px;
            border-radius: 25px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            z-index: 20;
            transition: all 0.3s;
            box-shadow: 0 5px 20px rgba(0, 212, 170, 0.3);
        }
        
        .complete-delivery-btn:hover {
            transform: translateX(-50%) translateY(-2px);
            box-shadow: 0 8px 25px rgba(0, 212, 170, 0.4);
        }
        
        /* 手勢提示 */
        .gesture-hint {
            position: absolute;
            bottom: 120px;
            left: 50%;
            transform: translateX(-50%);
            color: rgba(255, 255, 255, 0.7);
            font-size: 12px;
            animation: fadeInOut 3s infinite;
        }
        
        @keyframes fadeInOut {
            0%, 100% { opacity: 0.3; }
            50% { opacity: 0.8; }
        }
        
        /* 響應式調整 */
        @media (max-width: 375px) {
            .status-content {
                padding: 10px 15px;
            }
            
            .delivery-info h3 {
                font-size: 16px;
            }
            
            .delivery-info .distance {
                font-size: 14px;
            }
        }
    </style>
    <script src="https://maps.googleapis.com/maps/api/js?key=<%= process.env.GOOGLE_MAPS_API_KEY %>&libraries=geometry"></script>
</head>
<body>
    <!-- Google Maps 地圖容器 -->
    <div id="map-container">
        <div id="google-map"></div>
        <button class="gps-button" onclick="getCurrentLocation()">📍</button>
    </div>
    
    <!-- 底部狀態列 -->
    <div class="bottom-status-bar" onclick="toggleOrdersPanel()">
        <div class="status-content">
            <div class="delivery-info">
                <h3 id="current-customer">張小明</h3>
                <div class="distance" id="remaining-distance">剩餘 2.3 公里</div>
                <div class="eta" id="estimated-time">預計 8 分鐘抵達</div>
            </div>
            <div class="pull-indicator">↑</div>
        </div>
    </div>
    
    <!-- 手勢提示 -->
    <div class="gesture-hint">👆 點擊或向上滑動查看所有訂單</div>
    
    <!-- 可拉升的訂單面板 -->
    <div class="orders-panel" id="orders-panel">
        <div class="panel-handle" onclick="toggleOrdersPanel()"></div>
        
        <div class="orders-header">
            <h2>今日配送</h2>
            <div class="orders-summary">已完成 2 筆 • 剩餘 3 筆</div>
        </div>
        
        <div class="orders-list">
            <!-- 正在配送的訂單 -->
            <div class="current-order">
                <h3>📍 正在配送 - 張小明</h3>
                <div class="order-address">新北市三峽區中山路123號 4樓</div>
            </div>
            
            <!-- 已完成訂單 -->
            <div class="completed-orders">
                <h3>✅ 已完成配送</h3>
                <div class="completed-order">
                    <h4>王大華 - 完成</h4>
                    <div class="order-address">新北市三峽區民權街45號</div>
                </div>
                <div class="completed-order">
                    <h4>李美玲 - 完成</h4>
                    <div class="order-address">新北市三峽區復興路67號</div>
                </div>
            </div>
            
            <!-- 待配送訂單 -->
            <div class="pending-orders">
                <h3>📦 即將配送</h3>
                <div class="pending-order">
                    <h4>陳志明</h4>
                    <div class="order-address">新北市三峽區學成路89號</div>
                </div>
                <div class="pending-order">
                    <h4>林雅婷</h4>
                    <div class="order-address">新北市三峽區中華路156號 2樓</div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- 完成配送按鈕 -->
    <button class="complete-delivery-btn" onclick="completeCurrentDelivery()">
        ✅ 完成此筆配送
    </button>
    
    <script>
        let map;
        let directionsService;
        let directionsRenderer;
        let currentPosition;
        let ordersPanel = document.getElementById('orders-panel');
        let isPanelExpanded = false;
        
        // 初始化 Google Maps
        function initMap() {
            // 預設位置（新北市三峽區）
            const defaultCenter = { lat: 24.9342, lng: 121.3706 };
            
            map = new google.maps.Map(document.getElementById('google-map'), {
                zoom: 15,
                center: defaultCenter,
                mapTypeControl: false,
                streetViewControl: false,
                fullscreenControl: false,
                styles: [
                    {
                        "featureType": "all",
                        "elementType": "geometry.fill",
                        "stylers": [{"color": "#1a1a1a"}]
                    },
                    {
                        "featureType": "water",
                        "elementType": "geometry",
                        "stylers": [{"color": "#2d2d2d"}]
                    },
                    {
                        "featureType": "road",
                        "elementType": "geometry",
                        "stylers": [{"color": "#404040"}]
                    }
                ]
            });
            
            directionsService = new google.maps.DirectionsService();
            directionsRenderer = new google.maps.DirectionsRenderer({
                suppressMarkers: false,
                polylineOptions: {
                    strokeColor: '#00d4aa',
                    strokeWeight: 4
                }
            });
            directionsRenderer.setMap(map);
            
            // 獲取當前位置
            getCurrentLocation();
            
            // 顯示配送路線
            showDeliveryRoute();
        }
        
        // 獲取當前位置
        function getCurrentLocation() {
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(
                    (position) => {
                        currentPosition = {
                            lat: position.coords.latitude,
                            lng: position.coords.longitude
                        };
                        
                        map.setCenter(currentPosition);
                        
                        // 添加當前位置標記
                        new google.maps.Marker({
                            position: currentPosition,
                            map: map,
                            title: '我的位置',
                            icon: {
                                url: 'data:image/svg+xml;charset=UTF-8,' + encodeURIComponent(`
                                    <svg width="20" height="20" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                                        <circle cx="10" cy="10" r="8" fill="#00d4aa" stroke="#fff" stroke-width="2"/>
                                        <circle cx="10" cy="10" r="3" fill="#fff"/>
                                    </svg>
                                `),
                                scaledSize: new google.maps.Size(20, 20)
                            }
                        });
                    },
                    (error) => {
                        console.log('無法獲取位置:', error);
                    },
                    {
                        enableHighAccuracy: true,
                        timeout: 10000,
                        maximumAge: 300000
                    }
                );
            }
        }
        
        // 顯示配送路線
        function showDeliveryRoute() {
            // 模擬配送地址
            const deliveryAddress = "新北市三峽區中山路123號";
            
            if (currentPosition) {
                const request = {
                    origin: currentPosition,
                    destination: deliveryAddress,
                    travelMode: google.maps.TravelMode.DRIVING,
                    avoidHighways: false,
                    avoidTolls: false
                };
                
                directionsService.route(request, (result, status) => {
                    if (status === 'OK') {
                        directionsRenderer.setDirections(result);
                        
                        // 更新距離和時間資訊
                        const route = result.routes[0].legs[0];
                        document.getElementById('remaining-distance').textContent = 
                            `剩餘 ${route.distance.text}`;
                        document.getElementById('estimated-time').textContent = 
                            `預計 ${route.duration.text} 抵達`;
                    }
                });
            }
        }
        
        // 切換訂單面板
        function toggleOrdersPanel() {
            isPanelExpanded = !isPanelExpanded;
            ordersPanel.classList.toggle('expanded', isPanelExpanded);
        }
        
        // 完成當前配送
        function completeCurrentDelivery() {
            if (confirm('確認完成此筆配送？')) {
                // 這裡會調用後端API更新訂單狀態
                alert('✅ 配送完成！系統將自動導航至下一個配送點。');
                
                // 模擬移動到下一個訂單
                setTimeout(() => {
                    updateToNextOrder();
                }, 1000);
            }
        }
        
        // 更新到下一個訂單
        function updateToNextOrder() {
            document.getElementById('current-customer').textContent = '陳志明';
            document.getElementById('remaining-distance').textContent = '剩餘 1.8 公里';
            document.getElementById('estimated-time').textContent = '預計 6 分鐘抵達';
            
            // 更新訂單面板顯示
            updateOrdersPanel();
            
            // 重新計算路線
            showDeliveryRoute();
        }
        
        // 更新訂單面板
        function updateOrdersPanel() {
            // 這裡可以通過 AJAX 從後端獲取最新的訂單狀態
            console.log('更新訂單面板...');
        }
        
        // 觸控手勢支援
        let startY = 0;
        let currentY = 0;
        
        ordersPanel.addEventListener('touchstart', (e) => {
            startY = e.touches[0].clientY;
        });
        
        ordersPanel.addEventListener('touchmove', (e) => {
            currentY = e.touches[0].clientY;
            const diff = startY - currentY;
            
            if (diff > 50 && !isPanelExpanded) {
                toggleOrdersPanel();
            } else if (diff < -50 && isPanelExpanded) {
                toggleOrdersPanel();
            }
        });
        
        // 載入完成後初始化地圖
        window.onload = function() {
            initMap();
        };
    </script>
</body>
</html>