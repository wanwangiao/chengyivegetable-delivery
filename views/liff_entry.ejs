<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>承億蔬菜外送 - LINE 專屬入口</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: 'Microsoft YaHei', Arial, sans-serif;
      background: linear-gradient(135deg, #67B26F, #4ca2cd);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #333;
    }
    
    .container {
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(10px);
      border-radius: 20px;
      padding: 40px;
      text-align: center;
      box-shadow: 0 8px 32px rgba(31, 38, 135, 0.37);
      border: 1px solid rgba(255, 255, 255, 0.18);
      max-width: 400px;
      width: 90%;
    }
    
    .logo {
      font-size: 4em;
      margin-bottom: 20px;
    }
    
    h1 {
      color: #2d3748;
      margin-bottom: 10px;
      font-size: 1.8em;
    }
    
    .subtitle {
      color: #4a5568;
      margin-bottom: 30px;
      font-size: 1.1em;
    }
    
    .status {
      padding: 15px;
      border-radius: 10px;
      margin: 20px 0;
      font-weight: bold;
    }
    
    .status.loading {
      background: #e6fffa;
      color: #234e52;
      border: 2px solid #81e6d9;
    }
    
    .status.success {
      background: #c6f6d5;
      color: #22543d;
      border: 2px solid #68d391;
    }
    
    .status.error {
      background: #fed7d7;
      color: #c53030;
      border: 2px solid #fc8181;
    }
    
    .btn {
      background: linear-gradient(45deg, #48bb78, #38a169);
      color: white;
      border: none;
      padding: 15px 30px;
      border-radius: 25px;
      font-size: 1.1em;
      font-weight: bold;
      cursor: pointer;
      text-decoration: none;
      display: inline-block;
      transition: all 0.3s ease;
      margin: 10px;
    }
    
    .btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    }
    
    .btn.secondary {
      background: linear-gradient(45deg, #4299e1, #3182ce);
    }
    
    .spinner {
      border: 3px solid #f3f3f3;
      border-top: 3px solid #38a169;
      border-radius: 50%;
      width: 30px;
      height: 30px;
      animation: spin 1s linear infinite;
      margin: 0 auto 15px;
    }
    
    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }
    
    .user-info {
      background: #f7fafc;
      border-radius: 10px;
      padding: 15px;
      margin: 20px 0;
      text-align: left;
    }
    
    .user-info strong {
      color: #2d3748;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="logo">🥬</div>
    <h1>承億蔬菜外送</h1>
    <p class="subtitle">LINE 專屬購物入口</p>
    
    <div id="status" class="status loading">
      <div class="spinner"></div>
      正在初始化 LINE 服務...
    </div>
    
    <div id="userInfo" class="user-info" style="display: none;">
      <strong>歡迎：</strong><span id="displayName"></span><br>
      <strong>LINE ID：</strong><span id="userId"></span>
    </div>
    
    <div id="actions" style="display: none;">
      <a href="/" class="btn">🛒 開始購物</a>
    </div>
  </div>

  <!-- LINE LIFF SDK -->
  <script charset="utf-8" src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
  
  <script>
    // LIFF ID (需要從環境變數取得)
    const LIFF_ID = '<%= liffId %>';
    
    async function checkExistingUser() {
      try {
        // 檢查 localStorage 是否可用
        if (typeof(Storage) === "undefined") {
          console.log('⚠️ 瀏覽器不支援 localStorage，跳過快速登入');
          return false;
        }

        // 檢查是否已有用戶資料
        const existingProfile = localStorage.getItem('lineProfile');
        if (existingProfile && existingProfile.trim() !== '') {
          try {
            const profile = JSON.parse(existingProfile);

            // 驗證資料完整性
            if (profile && profile.userId && profile.displayName) {
              console.log('⚡ 發現有效的用戶資料，快速跳轉');
              console.log('👤 用戶:', profile.displayName, '(ID:', profile.userId, ')');

              // 安全跳轉
              window.location.href = '/';
              return true;
            } else {
              console.log('⚠️ 用戶資料不完整，清除並重新初始化');
              localStorage.removeItem('lineProfile');
            }
          } catch (parseError) {
            console.log('🔄 用戶資料格式錯誤，清除並重新初始化:', parseError.message);
            localStorage.removeItem('lineProfile');
          }
        }
      } catch (error) {
        console.error('❌ 檢查現有用戶時發生錯誤:', error);
        // 發生錯誤時安全地清除可能損壞的資料
        try {
          localStorage.removeItem('lineProfile');
        } catch (removeError) {
          console.error('❌ 清除 localStorage 失敗:', removeError);
        }
      }

      return false;
    }

    async function initializeLIFF() {
      try {
        console.log('🔄 初始化 LIFF...');

        // 初始化 LIFF
        await liff.init({ liffId: LIFF_ID });
        console.log('✅ LIFF 初始化成功');

        if (!liff.isLoggedIn()) {
          console.log('🔐 用戶未登入，開始登入流程');
          liff.login();
          return;
        }

        console.log('👤 用戶已登入，取得用戶資訊');

        // 取得用戶資訊
        const profile = await liff.getProfile();
        console.log('📱 用戶資訊:', profile);

        // 檢查是否為回訪用戶（加強安全檢查）
        let isReturningUser = false;
        try {
          const existingProfile = localStorage.getItem('lineProfile');
          if (existingProfile && existingProfile.trim() !== '') {
            const existingData = JSON.parse(existingProfile);
            isReturningUser = existingData && existingData.userId === profile.userId;
          }
        } catch (error) {
          console.log('⚠️ 檢查回訪用戶時發生錯誤，當作新用戶處理:', error.message);
          // 清除可能損壞的資料
          try {
            localStorage.removeItem('lineProfile');
          } catch (removeError) {
            console.error('❌ 清除損壞資料失敗:', removeError);
          }
        }

        if (isReturningUser) {
          console.log('🎯 回訪用戶，更新資料並立即跳轉');
          try {
            // 更新用戶資料
            localStorage.setItem('lineProfile', JSON.stringify(profile));
            // 安全跳轉
            window.location.href = '/';
            return;
          } catch (error) {
            console.error('❌ 儲存回訪用戶資料失敗:', error);
            // 即使儲存失敗也跳轉，不影響用戶體驗
            window.location.href = '/';
            return;
          }
        }

        // 新用戶流程 - 安全版本
        console.log('✨ 新用戶，儲存資料並導向');

        try {
          // 儲存用戶資料到 localStorage，稍後結帳時使用
          localStorage.setItem('lineProfile', JSON.stringify(profile));
          console.log('✅ LINE 用戶資料已儲存');
        } catch (storageError) {
          console.error('⚠️ 儲存用戶資料失敗，但不影響購物:', storageError);
          // 即使儲存失敗也繼續，只是下次無法快速登入
        }

        // 顯示簡短歡迎訊息（防止用戶困惑）
        try {
          document.getElementById('status').className = 'status success';
          document.getElementById('status').innerHTML = `✅ 歡迎 ${profile.displayName}！`;
        } catch (uiError) {
          console.error('⚠️ 更新UI失敗:', uiError);
        }

        // 安全跳轉（有備援機制）
        setTimeout(() => {
          try {
            window.location.href = '/';
          } catch (redirectError) {
            console.error('❌ 自動跳轉失敗，顯示手動連結:', redirectError);
            // 跳轉失敗時顯示手動按鈕
            try {
              document.getElementById('status').innerHTML = `
                跳轉失敗，請點擊下方按鈕：<br>
                <a href="/" class="btn">🛒 進入購物頁面</a>
              `;
              document.getElementById('actions').style.display = 'block';
            } catch (fallbackError) {
              console.error('❌ 顯示備援按鈕也失敗:', fallbackError);
            }
          }
        }, 500); // 給用戶 0.5 秒看歡迎訊息

      } catch (error) {
        console.error('❌ LIFF 初始化失敗:', error);

        document.getElementById('status').className = 'status error';
        document.getElementById('status').innerHTML = `
          ❌ 初始化失敗<br>
          <small>錯誤：${error.message}</small><br>
          <small>請重新開啟或聯繫客服</small>
        `;
      }
    }
    
    // 安全初始化函數
    async function safeInitialize() {
      try {
        console.log('📱 LIFF 入口頁面已載入');

        // 檢查是否有 LIFF ID
        if (!LIFF_ID || LIFF_ID === '' || LIFF_ID === 'undefined') {
          console.error('❌ LIFF ID 配置錯誤');
          document.getElementById('status').className = 'status error';
          document.getElementById('status').innerHTML = `
            ❌ 設定錯誤<br>
            <small>LIFF ID 未設定</small><br>
            <small>請聯繫系統管理員</small><br>
            <a href="/" class="btn secondary">🏠 回到首頁</a>
          `;
          document.getElementById('actions').style.display = 'block';
          return;
        }

        // 檢查是否支援 LIFF
        if (typeof liff === 'undefined') {
          console.error('❌ LIFF SDK 未載入');
          document.getElementById('status').className = 'status error';
          document.getElementById('status').innerHTML = `
            ❌ 載入錯誤<br>
            <small>LIFF SDK 未正確載入</small><br>
            <a href="/" class="btn secondary">🏠 直接進入購物</a>
          `;
          document.getElementById('actions').style.display = 'block';
          return;
        }

        console.log('🔍 檢查回訪用戶...');

        // 先檢查是否為回訪用戶（優先跳轉）
        const isExistingUser = await checkExistingUser();

        if (!isExistingUser) {
          console.log('🔄 進行 LIFF 初始化...');
          // 如果不是回訪用戶，才進行完整的 LIFF 初始化
          await initializeLIFF();
        }

      } catch (error) {
        console.error('❌ 初始化過程發生嚴重錯誤:', error);

        // 顯示錯誤訊息和備援選項
        try {
          document.getElementById('status').className = 'status error';
          document.getElementById('status').innerHTML = `
            ❌ 載入失敗<br>
            <small>${error.message || '未知錯誤'}</small><br>
            <small>您仍可以直接進入購物</small>
          `;

          // 提供備援按鈕
          document.getElementById('actions').innerHTML = `
            <a href="/" class="btn">🛒 直接進入購物</a>
            <button class="btn secondary" onclick="location.reload()">🔄 重新載入</button>
          `;
          document.getElementById('actions').style.display = 'block';

        } catch (uiError) {
          console.error('❌ 連錯誤UI都無法顯示:', uiError);
          // 最後手段：直接跳轉
          setTimeout(() => {
            window.location.href = '/';
          }, 2000);
        }
      }
    }

    // 頁面載入時初始化
    window.addEventListener('DOMContentLoaded', safeInitialize);
    
    // 全域錯誤處理
    window.addEventListener('error', function(event) {
      console.error('📱 頁面錯誤:', event.error);

      try {
        document.getElementById('status').className = 'status error';
        document.getElementById('status').innerHTML = `
          ❌ 載入錯誤<br>
          <small>發生未預期的錯誤</small><br>
          <a href="/" class="btn secondary">🏠 直接進入購物</a>
        `;
        document.getElementById('actions').style.display = 'block';
      } catch (fallbackError) {
        console.error('❌ 錯誤處理也失敗，執行緊急跳轉');
        // 緊急情況：3秒後強制跳轉
        setTimeout(() => {
          window.location.href = '/';
        }, 3000);
      }
    });

    // 處理未捕獲的 Promise 錯誤
    window.addEventListener('unhandledrejection', function(event) {
      console.error('📱 未處理的 Promise 錯誤:', event.reason);

      try {
        document.getElementById('status').className = 'status error';
        document.getElementById('status').innerHTML = `
          ❌ 服務錯誤<br>
          <small>LINE 服務暫時不可用</small><br>
          <a href="/" class="btn secondary">🛒 直接購物</a>
        `;
        document.getElementById('actions').style.display = 'block';
      } catch (fallbackError) {
        console.error('❌ 無法顯示錯誤訊息，直接跳轉');
        setTimeout(() => {
          window.location.href = '/';
        }, 2000);
      }
    });

    // 頁面離開前的清理（防止記憶體洩漏）
    window.addEventListener('beforeunload', function() {
      try {
        // 清理可能的計時器或監聽器
        console.log('🧹 清理頁面資源');
      } catch (error) {
        console.error('清理錯誤:', error);
      }
    });
  </script>
</body>
</html>