# 誠憶鮮蔬線上系統 - 環境變數範本
# 請複製此檔案為 .env 並填入實際值

# 資料庫連接設定
# Railway 會自動提供 DATABASE_URL，本地開發請設置實際值
DATABASE_URL=your_database_connection_string

# Node.js 環境設定
NODE_ENV=development
PORT=3050

# 管理員設定 - 請使用強密碼
ADMIN_EMAIL=your_admin_email@example.com
ADMIN_PASSWORD=your_secure_admin_password

# Session 安全設定 - 請使用至少32字元的隨機字串
SESSION_SECRET=your_secure_session_secret_key_here_at_least_32_chars

# 系統設定
SYSTEM_NAME=誠憶鮮蔬外送系統

# LINE Bot 設定 - 請在 LINE Developers Console 取得
LINE_CHANNEL_ID=your_line_channel_id
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_LIFF_ID=your_line_liff_id

# Google Maps API - 請在 Google Cloud Console 取得
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# 示範模式設定
DEMO_MODE=auto

# 示範外送員帳號 (僅供測試用)
DEMO_DRIVER_PHONE=0912345678
DEMO_DRIVER_PASSWORD=demo_driver_password

# 生產環境額外設定
# TZ=Asia/Taipei
# LOG_LEVEL=info
# MAX_UPLOAD_SIZE=5mb